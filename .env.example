# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Anthropic (для генерации плана через Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Опционально: ограничить бота одним пользователем (узнать ID через @userinfobot)
ALLOWED_USER_ID=123456789

# Опционально: MLX Whisper модель (берётся из HuggingFace кэша)
# WHISPER_MODEL=mlx-community/whisper-large-v3-mlx  # уже скачана (по умолчанию)
# WHISPER_MODEL=mlx-community/whisper-medium-mlx    # быстрее, менее точная

# Опционально: путь к SQLite базе (по умолчанию data/bot.db)
# DB_PATH=data/bot.db
